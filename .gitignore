# ============================================================
#  .gitignore — Frontend Deteksi Kecelakaan (React + Vite)
# ============================================================

# ──────────────────────────────────────────────────────────
# DEPENDENCIES
# ──────────────────────────────────────────────────────────
node_modules/
.npm/
.pnp
.pnp.js
.yarn/

# ──────────────────────────────────────────────────────────
# BUILD OUTPUT
# ──────────────────────────────────────────────────────────
dist/
dist-ssr/
build/
.vite/
*.local

# ──────────────────────────────────────────────────────────
# ENVIRONMENT & SECRETS
# ──────────────────────────────────────────────────────────
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local

# ──────────────────────────────────────────────────────────
# CACHE & LOGS
# ──────────────────────────────────────────────────────────
.cache/
.eslintcache
.stylelintcache
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
logs/

# ──────────────────────────────────────────────────────────
# TESTING
# ──────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ──────────────────────────────────────────────────────────
# OS & EDITOR
# ──────────────────────────────────────────────────────────

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble

# VSCode
.vscode/
*.code-workspace

# JetBrains (WebStorm, dll.)
.idea/
*.iml

# Vim / Emacs
*.swp
*.swo
*~

# ──────────────────────────────────────────────────────────
# MISC
# ──────────────────────────────────────────────────────────
tmp/
temp/
*.tmp
*.bak
*.orig
